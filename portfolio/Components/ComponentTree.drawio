                <mxCell id="24" value="&lt;font style=&quot;font-size: 12px&quot;&gt;HomePageContainer will be the parent container for: Avatar, Title and Subtitle. The css will use flex and the children will have their own flex proitions in the MainHeadings.module.css&lt;/font&gt;" style="whiteSpace=wrap;html=1;aspect=fixed;fontSize=18;fontColor=#FFFFFF;strokeColor=#000000;fillColor=#660000;" vertex="1" parent="1">
                    <mxGeometry x="370" y="514" width="160" height="160" as="geometry"/>
                </mxCell>
                <mxCell id="26" value="&lt;font style=&quot;font-size: 12px&quot;&gt;Avatar Will use the MainHeadingContainer as a class (as it is a child component). It will use flex to position to the left of the container&lt;/font&gt;" style="whiteSpace=wrap;html=1;aspect=fixed;fontSize=18;fontColor=#FFFFFF;strokeColor=#000000;fillColor=#660000;" vertex="1" parent="1">
                    <mxGeometry x="179" y="514" width="160" height="160" as="geometry"/>
                </mxCell>
                <mxCell id="28" value="&lt;span style=&quot;font-size: 12px&quot;&gt;Both MainHeading.js + Subheading.js will have a shared container called MainTitileContainer. They will also use the HomePageContainer so that they can be positioned next to Avatar&lt;/span&gt;" style="whiteSpace=wrap;html=1;aspect=fixed;fontSize=18;fontColor=#FFFFFF;strokeColor=#000000;fillColor=#660000;" vertex="1" parent="1">
                    <mxGeometry x="629.5" y="517" width="167" height="167" as="geometry"/>
                </mxCell>
                <mxCell id="30" value="&lt;font style=&quot;font-size: 12px&quot;&gt;NavBar will be use flex so that it is at the top of the page. It will also use sticky so that it is consistently at the top of the page when scrolling&lt;/font&gt;" style="whiteSpace=wrap;html=1;aspect=fixed;fontSize=18;fontColor=#FFFFFF;strokeColor=#000000;fillColor=#660000;" vertex="1" parent="1">
                    <mxGeometry x="819" y="517" width="160" height="160" as="geometry"/>
                </mxCell>
